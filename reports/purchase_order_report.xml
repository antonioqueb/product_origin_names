<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Template para el reporte de Orden de Compra -->
    <template id="report_purchaseorder_document_origin" inherit_id="purchase.report_purchaseorder_document">
        <!-- Reemplazar el nombre del producto en las líneas de la orden de compra -->
        <xpath expr="//td[@id='product']/span[@t-field='line.name']" position="replace">
            <span t-out="line.display_name_override or line.name"/>
        </xpath>
    </template>
    
    <!-- Template para el reporte de Solicitud de Cotización -->
    <template id="report_purchasequotation_document_origin" inherit_id="purchase.report_purchasequotation_document">
        <!-- Reemplazar el nombre del producto en las líneas de la cotización -->
        <xpath expr="//td[@id='product']/span[@t-field='order_line.name']" position="replace">
            <span t-out="order_line.display_name_override or order_line.name"/>
        </xpath>
    </template>

    <!-- ═══════════════════════════════════════════════════════════════
         DISEÑO SOM sobre el reporte NATIVO de Orden de Compra.
         Se hereda el template de Odoo (no se crea un reporte adicional):
         la estructura y la lógica nativas quedan intactas — incluida la
         sustitución del nombre del proveedor de arriba — y solo se
         re-estiliza al canon del sistema de diseño global
         (stock_lot_dimensions.som_report_style).
    -->
    <template id="report_purchaseorder_document_som_style" inherit_id="purchase.report_purchaseorder_document">
        <xpath expr="//div[hasclass('page')]" position="inside">
            <t t-call="stock_lot_dimensions.som_report_style"/>
            <style type="text/css">
                /* Adaptación de la ESTRUCTURA NATIVA al canon SOM */
                .page h2 {
                    font-size: 15px !important;
                    font-weight: 800 !important;
                    text-transform: uppercase;
                    letter-spacing: 0.5px;
                    color: #222 !important;
                }
                #informations strong {
                    color: #555;
                    text-transform: uppercase;
                    font-size: 8.5px;
                    letter-spacing: 0.3px;
                    font-weight: 600;
                }
                #informations p, #informations span { font-size: 9px; font-weight: 600; }
                .page table.table thead th {
                    background-color: #2f2f2f !important;
                    color: #fff !important;
                    font-weight: bold !important;
                    padding: 4px 6px !important;
                    font-size: 9px !important;
                    border: none !important;
                }
                .page table.table thead th * { color: #fff !important; }
                .page table.table tbody td {
                    font-size: 9px !important;
                    padding: 4px 6px !important;
                    border: 1px solid #d8d8d8 !important;
                }
                .page table.table tbody tr:nth-child(even) td { background-color: #f7f7f7; }
                /* Totales: sin rejilla, cierre con línea gruesa canónica */
                #total table.table td, #total table.table th {
                    border: none !important;
                    font-size: 9.5px !important;
                    padding: 3px 8px !important;
                }
                #total table.table tr:last-child td,
                #total table.table tr:last-child th {
                    border-top: 2px solid #2f2f2f !important;
                    font-weight: 800 !important;
                    font-size: 10.5px !important;
                }
            </style>
        </xpath>
    </template>

    <!-- Mismo canon para la Solicitud de Cotización (comparte estructura) -->
    <template id="report_purchasequotation_document_som_style" inherit_id="purchase.report_purchasequotation_document">
        <xpath expr="//div[hasclass('page')]" position="inside">
            <t t-call="stock_lot_dimensions.som_report_style"/>
        </xpath>
    </template>
</odoo>