<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════════════════════════
         HISTORIAL DE PRECIOS DE COMPRA

         Vista de consulta sobre purchase.order.line para negociación con
         proveedores: qué material se le compró a quién, cuándo y A QUÉ
         PRECIO. Buscable por proveedor, por producto propio y por nombre
         de origen (mask_name, el nombre que usa el proveedor).
         ═══════════════════════════════════════════════════════════════════ -->

    <record id="view_purchase_price_history_list" model="ir.ui.view">
        <field name="name">purchase.order.line.price.history.list</field>
        <field name="model">purchase.order.line</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0"
                  default_order="som_date_order desc"
                  decoration-muted="state == 'cancel'">
                <field name="som_date_order" string="Fecha" widget="date" optional="show"/>
                <field name="partner_id" string="Proveedor" widget="som_many2one_link"/>
                <field name="product_id" string="Producto (mi nombre)" widget="som_many2one_link"/>
                <field name="mask_name" string="Nombre de origen" optional="show"/>
                <field name="product_qty" string="Cantidad" sum="Total"/>
                <field name="som_uom_name" string="Unidad" optional="show"/>
                <field name="price_unit" string="Precio unitario"/>
                <field name="currency_id" string="Divisa" optional="show"/>
                <field name="price_subtotal" string="Subtotal" widget="monetary" sum="Total" optional="show"/>
                <field name="order_id" string="Orden de compra" widget="som_many2one_link" optional="show"/>
                <field name="state" string="Estado" widget="badge" optional="hide"
                       decoration-success="state in ('purchase', 'done')"
                       decoration-info="state in ('draft', 'sent')"/>
            </list>
        </field>
    </record>

    <record id="view_purchase_price_history_search" model="ir.ui.view">
        <field name="name">purchase.order.line.price.history.search</field>
        <field name="model">purchase.order.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id" string="Proveedor"/>
                <field name="product_id" string="Producto (mi nombre)"/>
                <field name="mask_name" string="Nombre de origen"
                       filter_domain="[('mask_name', 'ilike', self)]"/>
                <field name="order_id" string="Orden de compra"/>

                <filter name="filter_confirmed" string="Compras confirmadas"
                        domain="[('state', 'in', ('purchase', 'done'))]"/>
                <filter name="filter_quotations" string="Cotizaciones (precios ofertados)"
                        domain="[('state', 'in', ('draft', 'sent'))]"/>
                <separator/>
                <filter name="filter_last_year" string="Últimos 12 meses"
                        domain="[('som_date_order', '&gt;=', (context_today() + relativedelta(months=-12)).strftime('%Y-%m-%d'))]"/>

                <group expand="0" string="Agrupar por">
                    <filter name="group_partner" string="Proveedor"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_product" string="Producto"
                            context="{'group_by': 'product_id'}"/>
                    <filter name="group_origin" string="Nombre de origen"
                            context="{'group_by': 'mask_name'}"/>
                    <filter name="group_date" string="Mes de compra"
                            context="{'group_by': 'som_date_order:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_purchase_price_history_pivot" model="ir.ui.view">
        <field name="name">purchase.order.line.price.history.pivot</field>
        <field name="model">purchase.order.line</field>
        <field name="arch" type="xml">
            <pivot string="Precios de compra" sample="1">
                <field name="product_id" type="row"/>
                <field name="partner_id" type="col"/>
                <field name="price_unit" type="measure"/>
                <field name="product_qty" type="measure"/>
                <field name="price_subtotal" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_purchase_price_history" model="ir.actions.act_window">
        <field name="name">Historial de Precios</field>
        <field name="res_model">purchase.order.line</field>
        <field name="view_mode">list,pivot</field>
        <field name="view_id" ref="view_purchase_price_history_list"/>
        <field name="search_view_id" ref="view_purchase_price_history_search"/>
        <field name="domain">[('display_type', '=', False), ('product_id', '!=', False)]</field>
        <field name="context">{'search_default_filter_confirmed': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Sin compras registradas todavía
            </p>
            <p>
                Aquí verás cada línea de compra con su proveedor, producto,
                nombre de origen y el precio pactado — ideal para negociar:
                "la última vez me lo vendiste a tanto".
            </p>
        </field>
    </record>

    <menuitem id="menu_purchase_price_history"
              name="Historial de Precios"
              parent="purchase.menu_purchase_root"
              action="action_purchase_price_history"
              sequence="25"/>
</odoo>
